<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - POS 雲端銷售系統</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container-fluid">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shop"></i> POS 系統
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMain">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <ul class="navbar-nav me-auto">
                        <!-- 前台 -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-display"></i> 前台
                            </a>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" asp-controller="Station" asp-action="Open">開帳</a></li>
                                <li><a class="dropdown-item" asp-controller="Reservation" asp-action="Index">訂位</a></li>
                                <li><a class="dropdown-item" asp-controller="Order" asp-action="Index">點餐</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item" asp-controller="Station" asp-action="HandOver">交班</a></li>
                            </ul>
                        </li>
                        <!-- 後台 -->
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-gear"></i> 後台
                            </a>
                            <ul class="dropdown-menu">
                                <li><h6 class="dropdown-header">資料管理</h6></li>
                                <li><a class="dropdown-item" asp-controller="UserMgmt" asp-action="Index">使用者管理</a></li>
                                <li><a class="dropdown-item" asp-controller="ProductMgmt" asp-action="Index">商品管理</a></li>
                                <li><a class="dropdown-item" asp-controller="StoreMgmt" asp-action="Index">商家管理</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><h6 class="dropdown-header">統計報表</h6></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="HandOver">交班表</a></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="SalesProduct">銷售商品統計</a></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="DailySales">日銷售額統計</a></li>
                                <li><a class="dropdown-item" asp-controller="Report" asp-action="ReturnItems">退貨明細</a></li>
                            </ul>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle"></i> @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">修改密碼</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="bi bi-box-arrow-right"></i> 登出
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </nav>

    <main class="container-fluid py-3">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

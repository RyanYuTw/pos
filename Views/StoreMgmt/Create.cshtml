@model Pos.Models.Store
@{ ViewData["Title"] = "新增商家"; }

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-shop"></i> 新增商家</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-4">
                            <label asp-for="Id" class="form-label">商家代碼</label>
                            <input asp-for="Id" class="form-control font-monospace" maxlength="8" required />
                            <span asp-validation-for="Id" class="text-danger small"></span>
                        </div>
                        <div class="col-4">
                            <label asp-for="BranchNo" class="form-label">分店編號</label>
                            <input asp-for="BranchNo" class="form-control" maxlength="4" />
                        </div>
                        <div class="col-8">
                            <label asp-for="Name" class="form-label">商家名稱</label>
                            <input asp-for="Name" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-12">
                            <label asp-for="Address" class="form-label">地址</label>
                            <input asp-for="Address" class="form-control" maxlength="500" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Telephone" class="form-label">電話</label>
                            <input asp-for="Telephone" class="form-control" maxlength="20" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Fax" class="form-label">傳真</label>
                            <input asp-for="Fax" class="form-control" maxlength="10" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Chairman" class="form-label">負責人</label>
                            <input asp-for="Chairman" class="form-control" maxlength="10" />
                        </div>
                        <div class="col-6">
                            <label asp-for="BusinessRegistrationCode" class="form-label">統一編號</label>
                            <input asp-for="BusinessRegistrationCode" class="form-control font-monospace" maxlength="10" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Email" class="form-label">Email</label>
                            <input asp-for="Email" type="email" class="form-control" maxlength="50" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Url" class="form-label">網址</label>
                            <input asp-for="Url" class="form-control" maxlength="200" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">銀行資訊</label>
                            <div class="row g-2">
                                <div class="col-4">
                                    <input asp-for="Bank" class="form-control" maxlength="50" placeholder="銀行" />
                                </div>
                                <div class="col-4">
                                    <input asp-for="BankingDepartment" class="form-control" maxlength="50" placeholder="分行" />
                                </div>
                                <div class="col-4">
                                    <input asp-for="BankAccount" class="form-control" maxlength="50" placeholder="帳號" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check2"></i> 儲存
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

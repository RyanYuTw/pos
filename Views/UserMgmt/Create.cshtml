@model Pos.Models.User
@{ ViewData["Title"] = "新增使用者"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-person-plus"></i> 新增使用者</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="UserId" class="form-label">帳號</label>
                            <input asp-for="UserId" class="form-control font-monospace" maxlength="20" required />
                            <span asp-validation-for="UserId" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Password" class="form-label">密碼</label>
                            <input asp-for="Password" type="password" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="Name" class="form-label">姓名</label>
                            <input asp-for="Name" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="EmployeeNo" class="form-label">員工編號</label>
                            <input asp-for="EmployeeNo" class="form-control font-monospace" maxlength="4" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="UserGroup" class="form-label">使用者群組</label>
                            <select asp-for="UserGroup" asp-items="ViewBag.UserGroups" class="form-select">
                                <option value="">-- 請選擇 --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label asp-for="IdNo" class="form-label">身分證號</label>
                            <input asp-for="IdNo" class="form-control font-monospace" maxlength="50" />
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check2"></i> 儲存
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

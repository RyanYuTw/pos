@model Pos.Models.User
@{ ViewData["Title"] = "編輯使用者"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-secondary text-white">
                <h5 class="mb-0"><i class="bi bi-person-gear"></i> 編輯使用者</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="UserId" class="form-label">帳號</label>
                            <input asp-for="UserId" class="form-control font-monospace" readonly />
                        </div>
                        <div class="col-6">
                            <label asp-for="Name" class="form-label">姓名</label>
                            <input asp-for="Name" class="form-control" maxlength="50" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="EmployeeNo" class="form-label">員工編號</label>
                            <input asp-for="EmployeeNo" class="form-control font-monospace" maxlength="4" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="UserGroup" class="form-label">使用者群組</label>
                            <select asp-for="UserGroup" asp-items="ViewBag.UserGroups" class="form-select">
                                <option value="">-- 請選擇 --</option>
                            </select>
                        </div>
                        <div class="col-6">
                            <label asp-for="IdNo" class="form-label">身分證號</label>
                            <input asp-for="IdNo" class="form-control font-monospace" maxlength="50" />
                        </div>
                        <div class="col-12 text-muted small">
                            最後更新：@Model.UpdateTime.ToString("yyyy/MM/dd HH:mm") by @Model.Updater
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-secondary flex-grow-1">
                            <i class="bi bi-check2"></i> 更新
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

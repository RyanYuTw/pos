@model IEnumerable<Pos.ViewModels.DailySalesViewModel>
@{ ViewData["Title"] = "日銷售額統計"; }

<h5 class="mb-3"><i class="bi bi-calendar-bar-chart"></i> 日銷售額統計</h5>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label small mb-1">年</label>
        <input type="number" name="year" class="form-control form-control-sm"
               value="@ViewBag.Year" min="2020" max="2099" style="width:80px" />
    </div>
    <div class="col-auto">
        <label class="form-label small mb-1">月</label>
        <input type="number" name="month" class="form-control form-control-sm"
               value="@ViewBag.Month" min="1" max="12" style="width:60px" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">查詢</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">此月份無銷售資料</div>
}
else
{
    var maxSales = Model.Max(r => r.TotalSales);
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>日期</th>
                            <th class="text-end">訂單數</th>
                            <th class="text-end">銷售額</th>
                            <th>比例</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in Model)
                        {
                            var pct = maxSales > 0 ? (int)(r.TotalSales / maxSales * 100) : 0;
                            <tr>
                                <td>@ViewBag.Year/@ViewBag.Month/@r.Day</td>
                                <td class="text-end">@r.OrderCount</td>
                                <td class="text-end fw-bold text-success">$@r.TotalSales.ToString("N0")</td>
                                <td style="min-width:100px">
                                    <div class="progress" style="height:12px">
                                        <div class="progress-bar bg-success" style="width:@pct%"></div>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                    <tfoot class="table-light fw-bold">
                        <tr>
                            <td>合計</td>
                            <td class="text-end">@Model.Sum(r => r.OrderCount)</td>
                            <td class="text-end text-success">$@Model.Sum(r => r.TotalSales).ToString("N0")</td>
                            <td></td>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 bg-light p-3">
                <div class="text-muted small mb-1">月銷售額合計</div>
                <div class="fs-3 fw-bold text-success">$@Model.Sum(r => r.TotalSales).ToString("N0")</div>
                <div class="text-muted small mt-2">總訂單數</div>
                <div class="fs-5 fw-bold">@Model.Sum(r => r.OrderCount) 筆</div>
                <div class="text-muted small mt-2">日均銷售</div>
                <div class="fs-5 fw-bold">$@(Model.Count() > 0 ? (Model.Sum(r => r.TotalSales) / Model.Count()).ToString("N0") : "0")</div>
            </div>
        </div>
    </div>
}

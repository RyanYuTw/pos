@model IEnumerable<Pos.ViewModels.SalesProductViewModel>
@{ ViewData["Title"] = "銷售商品統計"; }

<h5 class="mb-3"><i class="bi bi-bar-chart"></i> 銷售商品統計</h5>

<form method="get" class="row g-2 align-items-end mb-3">
    <div class="col-auto">
        <label class="form-label small mb-1">開始日期</label>
        <input type="date" name="startDate" class="form-control form-control-sm"
               value="@ViewBag.StartDate?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <label class="form-label small mb-1">結束日期</label>
        <input type="date" name="endDate" class="form-control form-control-sm"
               value="@ViewBag.EndDate?.ToString("yyyy-MM-dd")" />
    </div>
    <div class="col-auto">
        <label class="form-label small mb-1">商品編號</label>
        <input type="text" name="productNo" class="form-control form-control-sm"
               placeholder="選填" maxlength="5"
               value="@Context.Request.Query["productNo"]" style="width:80px" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-outline-primary btn-sm">查詢</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-info">此區間無銷售資料</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>商品編號</th>
                    <th>商品名稱</th>
                    <th class="text-end">銷售數量</th>
                    <th class="text-end">銷售金額</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model.OrderByDescending(r => r.TotalPrice))
                {
                    <tr>
                        <td class="font-monospace">@r.ProductNo</td>
                        <td>@r.ProductName</td>
                        <td class="text-end">@r.TotalAmount.ToString("N0")</td>
                        <td class="text-end fw-bold text-success">$@r.TotalPrice.ToString("N0")</td>
                    </tr>
                }
            </tbody>
            <tfoot class="table-light fw-bold">
                <tr>
                    <td colspan="2">合計</td>
                    <td class="text-end">@Model.Sum(r => r.TotalAmount).ToString("N0")</td>
                    <td class="text-end text-success">$@Model.Sum(r => r.TotalPrice).ToString("N0")</td>
                </tr>
            </tfoot>
        </table>
    </div>
}

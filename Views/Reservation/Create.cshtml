@model Pos.Models.Reservation
@{ ViewData["Title"] = "新增訂位"; }

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0"><i class="bi bi-calendar-plus"></i> 新增訂位</h5>
            </div>
            <div class="card-body">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

                    <input type="hidden" asp-for="No" />
                    <input type="hidden" asp-for="BookTime" id="BookTime" />

                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="BookDate" class="form-label">訂位日期</label>
                            <input asp-for="BookDate" type="date" class="form-control" id="BookDate" required />
                        </div>
                        <div class="col-6">
                            <label class="form-label">時間</label>
                            <input type="time" id="timeInput" class="form-control" value="18:00" required />
                        </div>
                        <div class="col-6">
                            <label asp-for="Contact" class="form-label">聯絡人</label>
                            <input asp-for="Contact" class="form-control" required maxlength="50" />
                            <span asp-validation-for="Contact" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="Phone" class="form-label">電話</label>
                            <input asp-for="Phone" class="form-control" required maxlength="10" />
                            <span asp-validation-for="Phone" class="text-danger small"></span>
                        </div>
                        <div class="col-6">
                            <label asp-for="TableNo" class="form-label">桌號</label>
                            <input asp-for="TableNo" class="form-control" maxlength="3" placeholder="選填" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Attendance" class="form-label">預計人數</label>
                            <input asp-for="Attendance" type="number" class="form-control" min="1" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Member" type="checkbox" class="form-check-input" />
                                <label asp-for="Member" class="form-check-label">會員</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Memo" class="form-label">備註</label>
                            <textarea asp-for="Memo" class="form-control" rows="2" maxlength="500"></textarea>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check2"></i> 儲存
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary">取消</a>
                    </div>
                </form>
                <script>
                    document.querySelector('form').addEventListener('submit', function () {
                        const date = document.getElementById('BookDate').value;
                        const time = document.getElementById('timeInput').value || '18:00';
                        document.getElementById('BookTime').value = date + 'T' + time + ':00';
                    });
                </script>
            </div>
        </div>
    </div>
</div>

@model Pos.Models.Orders
@{
    ViewData["Title"] = $"退貨 - {Model.No}";
    var productNames = (Dictionary<string, string>)ViewBag.ProductNames;
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <h5 class="mb-3"><i class="bi bi-arrow-counterclockwise"></i> 退貨
            <span class="badge bg-warning text-dark ms-2">單號 @Model.No</span>
        </h5>

        <form asp-action="Return" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="orderNo" value="@Model.No" />

            <div class="card shadow-sm mb-3">
                <div class="card-header">選擇退貨項目</div>
                <div class="card-body p-0">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th width="40"><input type="checkbox" id="checkAll" class="form-check-input" /></th>
                                <th>#</th>
                                <th>商品</th>
                                <th class="text-end">數量</th>
                                <th class="text-end">金額</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{var idx = 1;}
                            @foreach (var d in Model.Details.Where(d => d.Status != "2"))
                            {
                                <tr>
                                    <td>
                                        <input type="checkbox" name="returnSerialNos" value="@d.SerialNo"
                                               class="form-check-input item-check" />
                                    </td>
                                    <td>@idx</td>
                                    <td>@(productNames.TryGetValue(d.ProductNo, out var rn) ? rn : d.ProductNo)</td>
                                    <td class="text-end">@d.Amount</td>
                                    <td class="text-end">$@(((d.DiscountPrice ?? 0) * d.Amount).ToString("N0"))</td>
                                </tr>
                                idx++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger flex-grow-1"
                        onclick="return confirm('確定退貨選取項目？此動作無法復原。')">
                    <i class="bi bi-arrow-counterclockwise"></i> 確認退貨
                </button>
                <a asp-action="Receipt" asp-route-id="@Model.No" class="btn btn-outline-secondary">取消</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('checkAll').addEventListener('change', function () {
    document.querySelectorAll('.item-check').forEach(c => c.checked = this.checked);
});
</script>
}

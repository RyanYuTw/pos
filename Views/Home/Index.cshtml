@{ ViewData["Title"] = "主頁"; }

<div class="row g-4 mt-2">
    <div class="col-12">
        <h5 class="text-muted">歡迎，@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</h5>
    </div>

    <!-- 前台快捷 -->
    <div class="col-12">
        <h6 class="text-uppercase text-muted fw-bold mb-3"><i class="bi bi-display"></i> 前台操作</h6>
    </div>

    <div class="col-6 col-md-3">
        <a asp-controller="Station" asp-action="Open" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-power fs-2 text-success"></i>
                <div class="mt-2 fw-semibold">開帳</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Reservation" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-calendar-check fs-2 text-primary"></i>
                <div class="mt-2 fw-semibold">訂位</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Order" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-basket fs-2 text-warning"></i>
                <div class="mt-2 fw-semibold">點餐</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Station" asp-action="HandOver" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-arrow-left-right fs-2 text-secondary"></i>
                <div class="mt-2 fw-semibold">交班</div>
            </div>
        </a>
    </div>

    <!-- 後台快捷 -->
    <div class="col-12 mt-2">
        <h6 class="text-uppercase text-muted fw-bold mb-3"><i class="bi bi-gear"></i> 後台管理</h6>
    </div>

    <div class="col-6 col-md-3">
        <a asp-controller="ProductMgmt" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-box-seam fs-2 text-info"></i>
                <div class="mt-2 fw-semibold">商品管理</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="UserMgmt" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-people fs-2 text-purple"></i>
                <div class="mt-2 fw-semibold">使用者管理</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="Report" asp-action="DailySales" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-bar-chart fs-2 text-danger"></i>
                <div class="mt-2 fw-semibold">日銷售統計</div>
            </div>
        </a>
    </div>
    <div class="col-6 col-md-3">
        <a asp-controller="StoreMgmt" asp-action="Index" class="text-decoration-none">
            <div class="card border-0 shadow-sm text-center py-4 h-100 card-hover">
                <i class="bi bi-shop-window fs-2 text-dark"></i>
                <div class="mt-2 fw-semibold">商家設定</div>
            </div>
        </a>
    </div>
</div>
